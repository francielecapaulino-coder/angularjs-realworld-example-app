{
  "dashboard": {
    "id": null,
    "title": "Conduit Application Dashboard",
    "tags": ["conduit", "angular", "spring-boot"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "API Requests Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(api_requests_total[5m])",
            "legendFormat": "Requests/sec"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "HTTP Requests by Status",
        "type": "stat",
        "targets": [
          {
            "expr": "sum by (status) (http_requests_total)",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Application Logs (Recent)",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"conduit-backend-api\"}",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Trace Search",
        "type": "traces",
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "tempo",
              "uid": "tempo"
            }
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 16
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}