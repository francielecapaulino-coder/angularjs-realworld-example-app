{
  "name": "app-ng",
  "version": "0.0.0",
"scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:mutation": "stryker run",
"test:mutation:report": "stryker run --reporters=html,json",
    "test:mutation:quick": "stryker run --timeoutFactor=0.5 --concurrency=6",
    "cypress:run": "cypress run --spec cypress/e2e/integration.cy.ts",
    "cypress:open": "cypress open",
    "wdio": "wdio run wdio.conf.ts",
    "test:e2e": "npm run cypress:run && npm run wdio"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
"dependencies": {
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17", 
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/router": "^21.2.17",
"@angular/animations": "^21.2.17",
    "marked": "^15.0.12",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.0",
    "zone.js": "~0.15.0"
  },
"devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
"@angular/compiler-cli": "^21.2.17",
    "@types/node": "^22.10.5",
    "@stryker-mutator/core": "^9.6.1",
    "cypress": "^13.15.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "vitest": "^4.0.8",
    "webpack": "^5.97.1"
  }
}
